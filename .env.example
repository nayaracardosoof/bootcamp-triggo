# Token da Hugging Face. Necessário para usar modelos via Inference API.
HF_TOKEN=YOUR_HF_TOKEN_HERE
 
# Modelo usado pelo agente. Pode trocar por outro modelo compatível.
MODEL_ID=ollama/qwen2.5-coder:7b

# Configurações do Ollama.
OLLAMA_MODEL=ollama/qwen2.5-coder:7b
OLLAMA_API_BASE=
 
# Número máximo de passos do agente pesquisador/gerador de skills.
MAX_STEPS=2

# Google API Key. Necessário para usar a API do Google.
GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY_HERE
# Número máximo de passos do agente avaliador.
EVALUATION_MAX_STEPS=1

# Número máximo de passos do agente GAIA.
GAIA_MAX_STEPS=2
GAIA_MAX_RETRIES=1

# Endpoint da API do GAIA. Pode ser alterado para outro endpoint se necessário.
GAIA_API_BASE_URL=https://agents-course-unit4-scoring.hf.space

# Pasta usada para exportar relatórios em Markdown.
REPORTS_DIR=reports
 
# Pasta usada para exportar skills em Markdown e manifestos JSON de carregamento.
GENERATED_SKILLS_DIR=generated_skills

# Pasta usada para avaliações em Markdown.
EVALUATIONS_DIR=evaluations

# Pasta usada para exportar os resultados das execuções do GAIA.
GAIA_RUNS_DIR=gaia_runs